fn <- paste0(fp, "time_series_19-covid-Confirmed.csv")
fn <- paste0(fp, "time_series_covid19_confirmed_global.csv")
### Ertrag einlesen und verarbeiten ###
df <- read.csv(file=fn,
header=TRUE, sep=",", quote="", dec=".",
stringsAsFactors=FALSE, fileEncoding="latin1")
pop <- read.csv(file="Population2018_FAO.csv",
header=TRUE, sep=";", quote="", dec=".",
stringsAsFactors=FALSE, fileEncoding="latin1")
pop$Value <- NULL
pop[pop$Country.Region=="United States of America","Country.Region"] <- "US"
pop[pop$Country.Region=="United Kingdom of Great Britain and Northern Ireland", "Country.Region"] <- "United Kingdom"
#dir()
#structure(df)
#df$
dfl <- df %>% gather(  key= "Date",  cases, c(X1.22.20:X7,16.20)  )
dfl <- as.data.frame(dfl)
dfl$Date <- gsub("X", "", dfl$Date)
dfl$Date <- gsub("Mar", "Mrz", dfl$Date)
dfl$Date <- gsub(".J", "J", dfl$Date)
dfl$Date <- gsub(".F", "F", dfl$Date)
dfl$Date <- gsub(".M", "M", dfl$Date)
dfl$Date <- as.Date(x = dfl$Date, format = "%m.%d.%y")
summary(dfl$Date)
summary(dfl$Country.Region)
levels(dfl$Country.Region)
dfl <- dfl[dfl$Country.Region!="",]
dfl <- dfl[dfl$Country.Region!="\"Korea",]
dfl$Country.Region <- factor(dfl$Country.Region)
dfl <- left_join(dfl, pop, by="Country.Region")
dfl$Country.Region <- factor(dfl$Country.Region)
# sum up regions within countrys
#sdf <- as.data.frame(dfl) %>% group_by(dfl$Country.Region, dfl$Date) %>% summarise(.,cases = sum(cases))
sdf <- aggregate(x = dfl["cases"], by = list(Country.Region=dfl$Country.Region, Date=dfl$Date), FUN = sum )
df <- df[!is.na(sdf$Country.Region),]
sel_countries <- c("Germany", "France", "Italy", "United Kingdom", "Spain", "India", "Brazil", "Sweden", "US")
df$Country.Region <- factor(df$Country.Region)
df <- sdf[sdf$Country.Region %in% sel_countries,]
rm(dfl)
rm(sdf)
#df <- df[!(as.character(df$Country.Region) == "France" & (df$Province.State != "France")),]
#df <- df[!(as.character(df$Country.Region) == "United Kingdom" & (df$Province.State != "United Kingdom")),]
df$Country.Region <- factor(df$Country.Region)
summary(df$Date)
summary(df$Country.Region)
df$Country.Region <- factor(df$Country.Region)
df <- df[df$cases>=100,]
df$log_cases <- log(df$cases)
mod.covid <- lm(formula = log_cases ~ Date*Country.Region, data = df)
summary(mod.covid)
anova(mod.covid)
df <- df[!is.na(df$Country.Region),]
#df_regCoef <- tidy(mod.covid, Country.Region)
df <-  df %>% arrange(Country.Region, Date) %>%  group_by(Country.Region)  %>%  mutate(newcases = cases - lag(cases)) #%>% na.omit()
summary(df$Country.Region)
df <- df[df$newcases>0,]
df <- df[!is.na(df$Country.Region),]
#df <-  df %>% arrange(Country.Region, Date) %>%  group_by(Country.Region)  %>%  mutate(cumdays = cumsum(count(df$cases))) #%>% na.omit()
firstrows <-  df %>% group_by(Country.Region) %>%  arrange(Date) %>% filter(row_number()==1 )
selrows <- paste(as.character(firstrows$Country.Region), as.character(firstrows$Date), sep = "_")
df$row_id <- paste(as.character(df$Country.Region), as.character(df$Date), sep = "_")
df[df$row_id %in% selrows,"newcases"] <- 0
df <- as.data.frame(df)
dates <- seq(as.Date("2020/2/20"), by = "day", length.out = 37)
dates
grid <- expand.grid(stringsAsFactors = TRUE, Date = dates, Country.Region = as.factor(sel_countries))
grid$log_cases <- predict( mod.covid, newdata = grid)
grid$cases <- exp(grid$log_cases)
breaks <- 10^(1:10)
minor_breaks <- rep(1:9, 21)*(10^rep(1:10, each=9))
p1<- NULL
p1 <-ggplot( )
p1 <- p1 + ggtitle(as.character(max(df$Date)))
p1 <- p1 + geom_point(data=df, aes( x=Date, y= cases, fill=Country.Region), size=4, alpha=0.8, shape=21)
p1 <- p1 + geom_line(data=grid, aes( x=Date, y= cases, color=Country.Region), size=2, alpha=0.8, lty=2 )
#p1 <- p1 + scale_shape_manual(values = MyShapes)
#p1 <- p1+ theme(legend.position="none")
p1 <- p1 + xlab("Datum")
p1 <- p1 + ylab("FÃ¤lle")
p1 <- set_theme(p1,22)
#p1 <- p1 + geom_smooth(data=df, aes( x=Date, y= cases, color=Country.Region),se=F)
#p1 <- p1 + scale_colour_discrete(guide = FALSE)
p1 <- p1 + theme(axis.text.x = element_text(angle = 30))
p1 <- p1 + facet_wrap(facets = vars(Country.Region),  ncol = 3)
p1 <- p1 + scale_y_log10(breaks = breaks, minor_breaks = minor_breaks, limits=c(100, 1e6))
p1 <- p1 + scale_fill_brewer(palette = "Set1")
p1 <- p1 + scale_color_brewer(palette = "Set1")
p1
ggsave(filename="COVID_19.png", plot=p1,  scale = 1, width = 24, height = 18, units = "cm", dpi = 300  )#,bg = "transparent")
p1 <- NULL
