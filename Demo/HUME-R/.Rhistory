GET(url, write_disk("R_factor.xlsx", overwrite=TRUE))
data <- read_excel("R_factor.xlsx", sheet="Nowcast_R")
head(data, 3)
data <- as.data.frame(data)
datum <- data[,1]
R <- data[,8]
R_lower <- data[,9]
R_upper <- data[,10]
df <- data.frame( datum = datum, R = R, R_upper = R_upper, R_lower=R_lower)
actDate <- tail(df$datum)
p1<- NULL
p1 <-ggplot(data=df, aes( x= datum, y= R) )
p1 <- p1 + ggtitle(actDate)
p1 <- p1 + geom_ribbon(data=df, aes(x= datum, ymin=R_lower, ymax=R_upper ), color="blue", fill="blue", alpha=0.2)
