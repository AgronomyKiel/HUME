# cumulative deaths
fp <- "C:/Users/h_kage/Documents/GitHub/COVID-19/csse_covid_19_data/csse_covid_19_time_series/"
#fn <- paste0(path, "COVID_16_03_2020.csv")
#fn <- paste0(fp, "time_series_19-covid-Confirmed.csv")
fn <- paste0(fp, "time_series_covid19_deaths_global.csv")
### Ertrag einlesen und verarbeiten ###
df_d_ <- read.csv(file=fn,
header=TRUE, sep=",", quote="", dec=".",
stringsAsFactors=FALSE, fileEncoding="latin1")
df_d_l <- df_d_ %>% gather(  key= "Date",  cases, c(X1.22.20:X7,16.20)  )
df_d_l <- as.data.frame(df_d_l)
df_d_l$Date <- gsub("X", "", df_d_l$Date)
df_d_l$Date <- gsub("Mar", "Mrz", df_d_l$Date)
df_d_l$Date <- gsub(".J", "J", df_d_l$Date)
df_d_l$Date <- gsub(".F", "F", df_d_l$Date)
df_d_l$Date <- gsub(".M", "M", df_d_l$Date)
df_d_l$Date <- as.Date(x = df_d_l$Date, format = "%m.%d.%y")
summary(df_d_l$Date)
summary(df_d_l$Country.Region)
levels(df_d_l$Country.Region)
df_d_l <- df_d_l[df_d_l$Country.Region!="",]
df_d_l <- df_d_l[df_d_l$Country.Region!="\"Korea",]
df_d_l$Country.Region <- factor(df_d_l$Country.Region)
# sum up regions within countrys
#sdf_d_ <- as.data.frame(df_d_l) %>% group_by(df_d_l$Country.Region, df_d_l$Date) %>% summarise(.,cases = sum(cases))
sdf_d_ <- aggregate(x = df_d_l["cases"], by = list(Country.Region=df_d_l$Country.Region, Date=df_d_l$Date), FUN = sum )
sdf_d_ <- left_join(sdf_d_, pop, by="Country.Region")
df_d_ <- df_d_[!is.na(sdf_d_$Country.Region),]
sel_countries <- c("Germany", "France", "Italy", "United Kingdom", "Spain", "India", "Brazil", "Sweden", "US")
df_d_$Country.Region <- factor(df_d_$Country.Region)
df_d_ <- sdf_d_[sdf_d_$Country.Region %in% sel_countries,]
rm(df_d_l)
rm(sdf_d_)
#df_d_ <- df_d_[!(as.character(df_d_$Country.Region) == "France" & (df_d_$Province.State != "France")),]
#df_d_ <- df_d_[!(as.character(df_d_$Country.Region) == "United Kingdom" & (df_d_$Province.State != "United Kingdom")),]
df_d_$Country.Region <- factor(df_d_$Country.Region)
summary(df_d_$Date)
summary(df_d_$Country.Region)
df_d_$Country.Region <- factor(df_d_$Country.Region)
df_d_ <- df_d_[df_d_$cases>=20,]
df_d_$log_cases <- log(df_d_$cases)
mod.covid <- lm(formula = log_cases ~ Date*Country.Region, data = df_d_)
summary(mod.covid)
anova(mod.covid)
df_d_ <- df_d_[!is.na(df_d_$Country.Region),]
#df_d__regCoef <- tidy(mod.covid, Country.Region)
df_d_ <-  df_d_ %>% arrange(Country.Region, Date) %>%  group_by(Country.Region)  %>%  mutate(newcases = cases - lag(cases)) #%>% na.omit()
df_d_ <- df_d_[df_d_$newcases>0,]
df_d_ <- df_d_[!is.na(df_d_$Country.Region),]
#df_d_ <-  df_d_ %>% arrange(Country.Region, Date) %>%  group_by(Country.Region)  %>%  mutate(cumdays = cumsum(count(df_d_$cases))) #%>% na.omit()
firstrows <-  df_d_ %>% group_by(Country.Region) %>%  arrange(Date) %>% filter(row_number()==1 )
selrows <- paste(as.character(firstrows$Country.Region), as.character(firstrows$Date), sep = "_")
df_d_$row_id <- paste(as.character(df_d_$Country.Region), as.character(df_d_$Date), sep = "_")
df_d_[df_d_$row_id %in% selrows,"newcases"] <- 0
df_d_ <- as.data.frame(df_d_)
dates <- seq(as.Date("2020/2/20"), by = "day", length.out = 45)
dates
grid <- expand.grid(stringsAsFactors = TRUE, Date = dates, Country.Region = as.factor(sel_countries))
grid$log_cases <- predict( mod.covid, newdata = grid)
grid$cases <- exp(grid$log_cases)
breaks <- 10^(1:10)
minor_breaks <- rep(1:9, 21)*(10^rep(1:10, each=9))
p1<- NULL
p1 <-ggplot( )
p1 <- p1 + ggtitle(as.character(max(df_d_$Date)))
p1 <- p1 + geom_point(data=df_d_, aes( x=Date, y= cases, fill=Country.Region), size=4, alpha=0.8, shape=21)
p1 <- p1 + geom_line(data=grid, aes( x=Date, y= cases, color=Country.Region), size=2, alpha=0.8, lty=2 )
#p1 <- p1 + scale_shape_manual(values = MyShapes)
#p1 <- p1+ theme(legend.position="none")
p1 <- p1 + xlab("Datum")
p1 <- p1 + ylab("TodesfÃ¤lle")
p1 <- set_theme(p1,22)
#p1 <- p1 + geom_smooth(data=df_d_, aes( x=Date, y= cases, color=Country.Region),se=F)
#p1 <- p1 + scale_colour_discrete(guide = FALSE)
p1 <- p1 + theme(axis.text.x = element_text(angle = 30))
p1 <- p1 + facet_wrap(facets = vars(Country.Region),  ncol = 3)
p1 <- p1 + scale_y_log10(breaks = breaks, minor_breaks = minor_breaks, limits=c(100, 1e6))
p1 <- p1 + scale_fill_brewer(palette = "Set1")
p1 <- p1 + scale_color_brewer(palette = "Set1")
p1
ggsave(filename="COVID_19_death_cases_log.png", plot=p1,  scale = 1, width = 24, height = 18, units = "cm", dpi = 300  )#,bg = "transparent")
