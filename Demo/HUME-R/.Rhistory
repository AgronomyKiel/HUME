df$Country.Region <- factor(df$Country.Region)
df$DOY <- df$Date - as.Date("2019-12-31")
df$DOY <- as.integer(df$DOY)
summary(df$DOY)
df_regp = df %>% group_by(Country.Region) %>%
do(fit_key = lm(log_cases ~ DOY , data = .))
# get the coefficients by group in a tidy data_frame
df_regpCoef <- tidy(df_regp, fit_key)
df_regpCoef <- as.data.frame(df_regpCoef)
#selcols <- c("Key", "term", "estimate")
#df_regpCoefs <- df_regpCoef[, selcols]
#df_regpCoefw <- spread(data = df_regpCoefs, key = term, value = estimate)
#df_regCoefs <- NULL
df_regpCoefw <- multi_spread(df = df_regpCoef, key = term, value = c(estimate:p.value))
df_regpCoef <- NULL
#names(df_regpCoefw)
nl <- NULL
nl <-  names(df_regpCoefw)
nl <- gsub(x = nl, pattern = "\\(Intercept\\)", replacement = "p0")
nl <- gsub(x = nl, pattern = "\\(", replacement = "")
nl <- gsub(x = nl, pattern = "\\)", replacement = "")
nl <- gsub(x = nl, pattern = "\\^", replacement = "")
nl <- gsub(x = nl, pattern = "INangebot2", replacement = "quad_p")
nl <- gsub(x = nl, pattern = "Nangebot", replacement = "slope_p")
nl <- gsub(x = nl, pattern = "_estimate", replacement = "")
#nl
names(df_regpCoefw) <- nl
df_regpstat = glance(df_regp, fit_key)
df_regp <- NULL
df_regpCoefw$t_2 <- log(2)/df_regpCoefw$DOY
df_regpCoefw$t100 <- log(100/exp(df_regpCoefw$p0))/df_regpCoefw$DOY
df_new <- df[df$Date>as.Date(max(df$Date)-5),]
df_new$DOY <- df_new$Date - as.Date("2019-12-31")
df_new$DOY <- as.integer(df_new$DOY)
summary(df_new$DOY)
df_regp_new = df_new %>% group_by(Country.Region) %>%
do(fit_key = lm(log_cases ~ DOY , data = .))
# get the coefficients by group in a tidy data_frame
df_regpCoef_new <- tidy(df_regp_new, fit_key)
df_regpCoef_new <- as.data.frame(df_regpCoef_new)
#selcols <- c("Key", "term", "estimate")
#df_regpCoefs <- df_regpCoef[, selcols]
#df_regpCoefw <- spread(data = df_regpCoefs, key = term, value = estimate)
#df_regCoefs <- NULL
df_regpCoefw_new <- multi_spread(df = df_regpCoef_new, key = term, value = c(estimate:p.value))
df_regpCoef_new <- NULL
#names(df_regpCoefw)
nl <- NULL
nl <-  names(df_regpCoefw_new)
nl <- gsub(x = nl, pattern = "\\(Intercept\\)", replacement = "p0")
nl <- gsub(x = nl, pattern = "\\(", replacement = "")
nl <- gsub(x = nl, pattern = "\\)", replacement = "")
nl <- gsub(x = nl, pattern = "\\^", replacement = "")
nl <- gsub(x = nl, pattern = "INangebot2", replacement = "quad_p")
nl <- gsub(x = nl, pattern = "Nangebot", replacement = "slope_p")
nl <- gsub(x = nl, pattern = "_estimate", replacement = "")
#nl
names(df_regpCoefw_new) <- nl
df_regpstat_new = glance(df_regp_new, fit_key)
df_regp_new <- NULL
df_regpCoefw_new$t_2 <- log(2)/df_regpCoefw_new$DOY
p1<- NULL
p1 <-ggplot(data=df_regpCoefw_new, aes( x= reorder(Country.Region, -df_regpCoefw_new$t_2), y= t_2, fill=Country.Region) )
