unit exel2ini;

{$mode objfpc}{$H+}

interface

uses
  Classes, SysUtils, FileUtil, LResources, Forms, Controls, Graphics, Dialogs,
  StdCtrls, EditBtn, IniFiles;

type

  { TForm1 }

  TForm1 = class(TForm)
    Label4: TLabel;
    OptionsFileNameEdit1: TFileNameEdit;
    OutputDirectoryEdit1: TDirectoryEdit;
    StateFileNameEdit1: TFileNameEdit;
    ParamFileNameEdit2: TFileNameEdit;
    StatFileNameEdit1 : TFileNameEdit;
    Label1: TLabel;
    Label2: TLabel;
    Label3: TLabel;
    Start: TButton;
    procedure StartClick(Sender: TObject);
  private
    { private declarations }
  public
    { public declarations }
    dirstr: String;

  end;

var
  Form1: TForm1;
  procedure createIni(fname: String; prefix: String; dirstr: String);
  function  getStatFiles(fname: String): TStringList;


implementation

{ TForm1 }


function getStatFiles(fname: String): TStringList;
var
 strList: TStringList;
  line: TStringList;
  captions: TStringList;
  component2paramlist: TStringList;
  actparamList: TStringList;
  i, j, k, idx: integer;
  namestr: string;
  Value: string;
  f: TextFile;
  help: TStringList;

begin
  strList  := TStringList.Create();
  captions := TStringList.Create();

  help := TStringList.create();
  component2paramlist := TStringList.Create();

  strList.LoadFromFile(fname);
  captions.Delimiter     := ';';
  captions.DelimitedText := strList[0];

  idx := 0;

  actParamList := TStringList.Create();

  for i := 1 to strList.Count - 1 do begin
    line := TStringList.Create();
    line.Delimiter := ';';
    line.DelimitedText := strList[i];

    if line.count <= 1 then
      Continue;

    if not (line.count >= captions.count) then begin
      showmessage(fname + '\nZeile: ' + inttostr(i) + '\n Spaltenanzahl in dieser Zeile: ' +
      inttostr(line.Count)  + '\nSpaltenanzahl in der Überschriftszeile: ' +
      inttostr(captions.count)  + '\nFehlerhafte Zeile: '  + ' ' + strList[i] + '\nProgrammabruch');
      exit;
    end;


    if AnsiPos('[', strList[i]) > 0 then begin
      if component2paramlist.indexOf(line[0]) < 0 then begin
        actParamList := TStringList.Create();
        component2paramlist.AddObject(line[0], actParamList);
        idx := component2paramlist.indexOf(line[0]);
      end else begin
        idx := component2paramlist.indexOf(line[0]);
      end;
   end else begin
       help := component2paramlist.objects[idx] as TStringList;
       help.AddObject(line[0], line);
    end
  end;

  result := component2paramlist;

{*
  for i := 1 to captions.Count - 1 do begin
    AssignFile(f, dirstr + '\' + prefix + captions[i] + '.ini');
    Rewrite(f);

    for j := 0 to component2paramlist.Count - 1 do begin
      namestr      := component2paramlist[j];
      actParamList := component2paramlist.Objects[j] as TStringList;
      Writeln(f, namestr);
      //showmessage(inttostr(actParamList.count));

      for k := 0 to actParamList.Count - 1 do begin
        line := actParamList.objects[k] as TStringList;
        //ShowMessage(inttostr(line.count));

        if line.Count >= captions.Count then begin
          Value := line[i];
          if (trim(value) <> '.') then
            Writeln(f, line[0] + '=' + Value);
        end else begin

        end
      end

    end;
    closefile(f);
  end;
*}
end;

procedure createIni(fname: String; prefix: String; dirstr: String);
var
 strList: TStringList;
  line: TStringList;
  captions: TStringList;
  component2paramlist: TStringList;
  actparamList: TStringList;
  i, j, k, idx: integer;
  namestr: string;
  Value: string;
  f: TextFile;
  help: TStringList;

begin
  strList  := TStringList.Create();
  captions := TStringList.Create();

  help := TStringList.create();
  component2paramlist := TStringList.Create();

  strList.LoadFromFile(fname);
  captions.Delimiter     := ';';
  captions.DelimitedText := strList[0];

  idx := 0;

  actParamList := TStringList.Create();

  for i := 1 to strList.Count - 1 do begin


    line := TStringList.Create();
    line.Delimiter := ';';
    line.DelimitedText := strList[i];

    if line.count <= 1 then
      Continue;

    if not (line.count >= captions.count) then begin
      showmessage(fname + '\nZeile: ' + inttostr(i) + '\n Spaltenanzahl in dieser Zeile: ' +
      inttostr(line.Count)  + '\nSpaltenanzahl in der Überschriftszeile: ' +
      inttostr(captions.count)  + '\nFehlerhafte Zeile: '  + ' ' + strList[i] + '\nProgrammabruch');
      exit;
    end;


    if AnsiPos('[', strList[i]) > 0 then begin
      if component2paramlist.indexOf(line[0]) < 0 then begin
        actParamList := TStringList.Create();
        component2paramlist.AddObject(line[0], actParamList);
        idx := component2paramlist.indexOf(line[0]);
      end else begin
        idx := component2paramlist.indexOf(line[0]);
      end;
   end else begin
       help := component2paramlist.objects[idx] as TStringList;
       help.AddObject(line[0], line);
    end
  end;

  for i := 1 to captions.Count - 1 do begin
    AssignFile(f, dirstr + '\' + prefix + captions[i] + '.ini');
    Rewrite(f);

    for j := 0 to component2paramlist.Count - 1 do begin
      namestr      := component2paramlist[j];
      actParamList := component2paramlist.Objects[j] as TStringList;
      Writeln(f, namestr);
      //showmessage(inttostr(actParamList.count));

      for k := 0 to actParamList.Count - 1 do begin
        line := actParamList.objects[k] as TStringList;
        //ShowMessage(inttostr(line.count));

        if line.Count >= captions.Count then begin
          Value := line[i];
          if (trim(value) <> '.') then
            Writeln(f, line[0] + '=' + Value);
        end else begin

        end
      end

    end;
    closefile(f);
  end;
end;

procedure TForm1.StartClick(Sender: TObject);
var
  strList2, strList: TStringList;
  captions, line: TStringList;
  i,j,k: integer;
  f: TextFile;
  ini: TIniFile;
  //w_file1, w_file2: String;
  w_file: TStringList;
  list: TStringList;
  namestr: string;
  Value: string;
  actparamList: TStringList;

begin
  dirstr := OutputDirectoryEdit1.Directory;

  createini(ParamFileNameEdit2.FileName,'params_',dirstr);
  createini(StateFileNameEdit1.FileName,'state_',dirstr);
  createini(OptionsFileNameEdit1.FileName,'options_',dirstr);

  captions := TStringList.Create();
  strList := TStringList.create();
  strList.LoadFromFile(ParamFileNameEdit2.FileName);
  captions.Delimiter     := ';';
  captions.DelimitedText := strList[0];

  strList2 := TStringList.create();
  strList2.LoadFromFile(OptionsFileNameEdit1.FileName);
  //w_file1 := '';
  //w_file2 := '';

  for i := 1 to strList2.Count - 1 do begin
    line := TStringList.Create();
    line.Delimiter := ';';
    line.DelimitedText := strList2[i];

    if line.count <= 1 then
      Continue;

    if AnsiPos('weather_input_file', line[0]) > 0 then begin
      w_file := line;
    end
  end;


  list := TStringList.create();
  list := getStatFiles(StatFileNameEdit1.FileName);
  //showmessage(inttostr(list.count));

  for i := 1 to captions.Count - 1 do begin
    AssignFile(f, dirstr + '\' + captions[i] + '.ini');
    Rewrite(f);

    writeln(f);
    writeln(f,'[FileNames]');
    writeln(f,'ParamIniFN=' + dirstr + '\params_' + captions[i] + '.ini');
    //writeln(f,'WeatherFileFN=' + w_file);

    if AnsiPos('s1',captions[i]) > 0 then begin
      writeln(f,'OptionsIniFN=' + dirstr+ '\options_s1_M1.ini');
      writeln(f,'StateIniFN=' + dirstr + '\state_s1_M1.ini');
      //writeln(f,'WeatherFileFN=' + w_file1);

      for j := 0 to w_file.count - 1 do begin
        if AnsiPos('s1',w_file[j]) > 0 then begin
          writeln(f,'WeatherFileFN=' + w_file[j]);
          break;
        end;
      end;
    end else if AnsiPos('Lindhof',captions[i]) > 0 then begin
      writeln(f,'OptionsIniFN=' + dirstr+ '\options_Lindhof.ini');
      writeln(f,'StateIniFN=' + dirstr + '\state_Lindhof.ini');
      //writeln(f,'WeatherFileFN=' + w_file1);

      for j := 0 to w_file.count - 1 do begin
        //if AnsiPos('s1',w_file[j]) > 0 then begin
          writeln(f,'WeatherFileFN=' + w_file[j]);
        //  break;
        //end;
      end;

    end else begin
      //writeln(f,'WeatherFileFN=' + w_file2);

      if AnsiPos('ff1',captions[i]) > 0 then begin
        writeln(f,'OptionsIniFN=' + dirstr+ '\options_s2_M1.ini');
        writeln(f,'StateIniFN=' + dirstr + '\state_s2_M1.ini');
      end else if AnsiPos('ff4',captions[i]) > 0 then begin
        writeln(f,'OptionsIniFN=' + dirstr+ '\options_s2_DW.ini');
        writeln(f,'StateIniFN=' + dirstr + '\state_s2_DW.ini');
      end;

      for j := 0 to w_file.count do begin
        if AnsiPos('s2',w_file[j]) > 0 then begin
          writeln(f,'WeatherFileFN=' + w_file[j]);
          break;
        end;
      end;

    end;
     writeln(f);
     //writeln(f,'[MeasurementFiles]');

     for j := 0 to list.Count - 1 do begin
      namestr      := list[j];
      //showmessage(namestr);
      actParamList := list.Objects[j] as TStringList;
      Writeln(f, namestr);
      //showmessage(inttostr(actParamList.count));

      for k := 0 to actParamList.Count - 1 do begin
        line := actParamList.objects[k] as TStringList;
        //ShowMessage(inttostr(line.count));

        if line.Count >= captions.Count then begin
          Value := line[i];
          if (trim(value) <> '.') then
            Writeln(f, line[0] + '=' + Value);
        end else begin

        end
      end

    end;

    writeln(f);
    writeln(f,'[TimeInit]');
    writeln(f,'Startzeit=40179');
    writeln(f,'Endzeit=40543');
    writeln(f,'TimeStep=1');
    writeln(f);
    //writeln(f,'[MeasurementFiles]');
    //writeln(f,'GrowthCurvePlantRoots1=' + dirstr + 'KD_DW_N1DMLAIHIGH.txt');
    //writeln(f,'GrowthCurvePlantRoots2=B:\Modelle\Niko\DATA\KD\Pflanze\KD_DW_N4DMLAIHIGH.txt');

    closefile(f);
  end;


  AssignFile(f, dirstr + '\prog.fn');
  Rewrite(f);
  for i := 1 to captions.Count - 1 do begin
    writeln(f,dirstr + '\' + captions[i] + '.ini');;
  end;
  closefile(f);

   ShowMessage('fertig.');

end;




initialization
  {$I exel2ini.lrs}

end.

