fn <- "csv_Hume_Docu/HumeWheatLeafArea1.csv"
df <- read.delim(fn, header = TRUE, sep = ";")
df.state <- df %>% filter(SubModel == "HumeWheatLeafArea1", EntityType == "State") %>% dplyr::select(EntityName, Units, Value, Comment)
names(df.state) <- c("State variable", "Units", "InitialValue", "Description")
#| echo: false
#| message: false
#| warning: false
kable(df.state)
#| message: false
#| warning: false
#| include: false
df.par <- df %>% filter(SubModel == "HumeWheatLeafArea1", EntityType == "Parameter") %>% dplyr::select(EntityName, Units, Value, Comment)
names(df.par) <- c("Parameter", "Units", "Value", "Description")
#| echo: false
#| message: false
#| warning: false
kable(df.par,  escape = FALSE)
#| message: false
#| warning: false
#| include: false
df.var <- df %>% filter(SubModel == "HumeWheatLeafArea1", EntityType == "Variable") %>% dplyr::select(EntityName, Units, Comment)
names(df.var) <- c("Variable", "Units", "Description")
kable(df.var,  escape = FALSE)
#| message: false
#| warning: false
#| include: false
df.ext <- df %>% filter(SubModel == "HumeWheatLeafArea1", EntityType == "ExtVar") %>% dplyr::select(EntityName, Units, Comment, Option)
names(df.ext) <- c("External variable", "Units", "Description", "Source")
#| echo: false
#| message: false
#| warning: false
kable(df.ext,  escape = FALSE)
#| message: false
#| warning: false
#| include: false
df.opt <- df %>% filter(SubModel == "HumeWheatLeafArea1",EntityType == "Option" ) %>% dplyr::select(EntityName, Units, Comment)
names(df.opt) <- c("Option", "Units", "Description")
#| echo: false
