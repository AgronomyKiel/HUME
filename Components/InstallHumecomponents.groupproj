    </Target>
    <Target Name="ISIP_Components:Clean">
        <MSBuild Projects="ISIP_Components\ISIP_Components.dproj" Targets="Clean"/>
    </Target>
    <Target Name="ISIP_Components:Make">
        <MSBuild Projects="ISIP_Components\ISIP_Components.dproj" Targets="Make"/>
    </Target>
    <Target Name="Build">
        <CallTarget Targets="SoilWaterPackage;CeresSubModels;PackageGrowthCurvePlantRootsDM;ISIP_Components"/>
    </Target>
    <Target Name="Clean">
        <CallTarget Targets="SoilWaterPackage:Clean;CeresSubModels:Clean;PackageGrowthCurvePlantRootsDM:Clean;ISIP_Components:Clean"/>
    </Target>
    <Target Name="Make">
        <CallTarget Targets="SoilWaterPackage:Make;CeresSubModels:Make;PackageGrowthCurvePlantRootsDM:Make;ISIP_Components:Make"/>
    </Target>
    <Import Project="$(BDS)\Bin\CodeGear.Group.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Group.Targets')"/>
