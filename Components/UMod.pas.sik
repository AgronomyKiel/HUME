implementation


uses
  FileCtrl, // Delphi VCL
  Forms,    // Delphi VCL
  UMrqMinD; // HUME: routines for parameter estimation (Marquard method)



(******************************************************************
CLASS   TMarquardOptions
METHOD  create
PURPOSE Creating an TMarquardOptions instance, used for parameter estimation
*******************************************************************)

constructor TMarquardOptions.create;

begin
  inherited create;
  FDivisor := 100;       // Value which is needed for numerical
                         // approximation of function derivative
  FIniLambda := 0.001;   // Initial value of parameter Lambda
  FDefaultError := 0.1;  // one may use an default error for weighting
end;


(******************************************************************
CLASS   TSensitivityOptions
METHOD  create
PURPOSE Create an TSensitivityOptions instance to save options for
        Sensitivity analysis used within the TMod class
*******************************************************************)

constructor TSensitivityOptions.create;

begin
  inherited create;
  FOutList := TStringList.create; // Variables selected for output
  FMinValue := 1.0;               // minimum value during sensitivity analysis
  FMaxValue := 10.0;              // maximum value during sensitivity analysis
  FSteps := 5;                    // Steps of sensitivity analysis
  FDPar := 1;
  FSens_fn := 'Sens.dat'          // output file name for sensitivity data
end;


(******************************************************************
CLASS   TSensitivityOptions
METHOD  SetMaxValue
PURPOSE Sets maximum value during sensitivity analysis
INPUT   const MAxValue: real
*******************************************************************)

procedure TSensitivityOptions.SetMaxValue(const MaxValue: real);

begin
  fMaxValue := MaxValue;
  FDPar := (FMaxValue - FMinValue) / (FSteps - 1);
end;


(******************************************************************
CLASS   TSensitivityOptions
METHOD  SetMinValue
PURPOSE Sets minimum value during sensitivity analysis
INPUT   const MinValue: real
*******************************************************************)

procedure TSensitivityOptions.SetMinValue(const MinValue: real);

begin
  fMinValue := MinValue;
  FDPar     := (FMaxValue - FMinValue) / (FSteps - 1);
end;


(******************************************************************
CLASS   TSensitivityOptions
METHOD  SetSteps
PURPOSE Sets number of steps of sensitivity analysis
INPUT   const Steps: integer
*******************************************************************)

procedure TSensitivityOptions.SetSteps(const Steps: integer);

begin
  fSteps := Steps;
  FDPar  := (FMaxValue - FMinValue) / (FSteps - 1);
end;


(******************************************************************
CLASS   TMod
METHOD  Paint
PURPOSE Method for showing object on the screen
*******************************************************************)

procedure TMod.Paint;
var
  x, y, w, h, s,
    text_left, text_top, text_length: integer;
  Titel: string;
begin
  Titel := Name;
  with Canvas do
    begin
      x := Pen.Width div 2;
      y := x;
      w := Width - Pen.Width + 1;
      h := Height - Pen.Width + 1;
      if w < h then s := w else s := h;
      RoundRect(x, y, x + w, y + h, 8, 8);
      text_length := TextWidth(Titel);
      text_left := (Width - text_length) div 2;
      TextOut(text_left, Height div 2 - TextHeight(Titel) div 2, Titel);
    end;
end;


(******************************************************************
CLASS   TMod
METHOD  Get_ControlFileFn
PURPOSE Gets name of Control file (published for use in object inspector)
OUTPUT  TMyFileName
*******************************************************************)

function TMod.Get_ControlFileFn: TMyFileName;
begin
  Result := ControlFileFn;
end;


(******************************************************************
CLASS   TMod
METHOD  get_fnStateIniFile
PURPOSE Gets name of State Ini file (published for use in object inspector)
OUTPUT  TMyFileName
*******************************************************************)

function TMod.get_fnStateIniFile: TMyFileName;

begin
  result := StateIniFile.FileName;
end;


(******************************************************************
CLASS   TMod
METHOD  Set_fnStateIniFile
PURPOSE Sets name of State Ini file (published for use in object inspector)
INPUT   const fn: TMyFileName
OUTPUT
COMMENT
*******************************************************************)

procedure TMod.Set_fnStateIniFile(const fn: TMyFileName);

begin
  If Fileexists(fn) then begin
    StateIniFile.Init(fn);
    If ActIniFile <> nil then
     ActIniFile.WriteString(str_SectionName_FileNames, str_SectionTopic_StateIniFN, fn);
  end;
end;


(******************************************************************
CLASS   TMod
METHOD  get_fnParamIniFile
PURPOSE PURPOSE Gets name of Parameter Ini file (published for use in object inspector)
OUTPUT  TMyFileName
*******************************************************************)

function TMod.get_fnParamIniFile: TMyFileName;

begin
  result := ParamIniFile.FileName;
end;


(******************************************************************
CLASS   TMod
METHOD  Set_fnParamIniFile
PURPOSE Sets name of Parameter Ini file (published for use in object inspector)
INPUT   const fn: TMyFileName
*******************************************************************)

procedure TMod.Set_fnParamIniFile(const fn: TMyFileName);

begin
  If Fileexists(fn) then begin
    ParamIniFile.Init(fn);
    If ActIniFile <> nil then
     ActIniFile.WriteString(str_SectionName_FileNames, str_SectionTopic_ParamIniFN, fn);
  end;
end;


(******************************************************************
CLASS   TMod
METHOD  get_fnweatherFile
PURPOSE Gets name of weather data file (published for use in object inspector)
OUTPUT  TMyFileName
*******************************************************************)

function TMod.get_fnweatherFile: TMyFileName;

begin
  result := WeatherFile.fFileName;
end;


(******************************************************************
CLASS   TMod
METHOD  Set_fnWeatherFile
PURPOSE Sets name of weather data file (published for use in object inspector)
INPUT   const fn: TMyFileName
*******************************************************************)

procedure TMod.Set_fnWeatherFile(const fn: TMyFileName);

begin
  If Fileexists(fn) then begin
    WeatherFile.fFileName := fn;
    WeatherFile.Init(fn);
    {ActIniFile.WriteString(str_SectionName_FileNames, str_SectionTopic_WeatherFileFN, fn);}
  end;
end;


(******************************************************************
CLASS   TMod
METHOD  Set_ControlFileFN
PURPOSE Sets name of control Ini file (published for use in object inspector)
INPUT   const fn: TMyFileName
COMMENT If no control files are existing they will be created
*******************************************************************)

procedure TMod.Set_ControlFileFN(const fn: TMyFileName);
var
  act_IniFn: string;
  NewInifile: TMyIniFile;
  DlgFileOpen: TopenDialog;
  index: integer;
  NewFile : boolean;

begin

  //control files have ".fn" file extension
  ControlFileFN := fn;
  //start dialog if no control file found on specified path
  if FileExists(fn) = false then begin
      DlgFileOpen := TOpenDialog.Create(Application);
      DlgFileOpen.Title := 'Open Control File';
      DlgFileOpen.Filename := '*.fn';
      DlgFileOpen.Filter := 'Controlfiles (*.fn)|*.fn';
      DlgFileOpen.Options := DlgFileOpen.Options + [ofShowHelp, ofPathMustExist,
        ofFileMustExist];
      try
        if DlgFileOpen.Execute then begin
          ControlFileFN := DlgFileOpen.Filename;
          assignfile(ControlFile, DlgFileOpen.Filename);
        end;
      finally
        DlgFileOpen.Free;
      end;
  end else begin;

    assignfile(ControlFile, fn);
  end;
    reset(ControlFile);
    FIniFiles := TStringList.Create;
    index := 0;

  // go through list of all Ini files specified in control file
  while not eof(ControlFile) do begin

      //open or create next Ini file and add to Ini file list of TMod
      NewFile := false;
      readln(ControlFile, Act_IniFn);
      if FileExists(Act_iniFN) = false then
        NewFile := true;
      NewIniFile := TMyIniFile.Create;
      NewInifile.init(Act_IniFn);
      {index := FInifiles.AddObject(NewIniFile.Filename, NewIniFile);}
      FIniFiles.add(NewInifile.FileName);
      FIniFiles.objects[index] := NewInifile;
      inc(index);
      // if Ini file is newly created put some default values in it
      If Newfile then begin
        NewInifile.WriteFloat(str_sectionname_timeinit, str_sectiontopic_simStart, 0.0);
        NewInifile.WriteFloat(str_sectionname_timeinit, str_sectiontopic_simEnd, 100.0);
        NewInifile.WriteFloat(str_sectionname_timeinit, str_sectiontopic_TimeStep, 1.0);

        NewInifile.Writestring(str_sectionname_FileNames, str_sectiontopic_StateIniFN, GetCurrentDir+'\State.ini');
        NewInifile.Writestring(str_sectionname_FileNames, str_sectiontopic_ParamIniFN, GetCurrentDir+'\Parameters_x.ini');

      end;

        {MessageDlg('IniFile ' + Act_IniFn + ' does not exist !',
          mtInformation, [mbOK], 0);
        end;}
    end;

  //activate and initialize first of all Ini files specified in control file
  ActIniFile := TMyIniFile(FInifiles.objects[0]);
  //f_ParamIniFile.FileName := ActIniFile.ReadString(Str_SectionName_FileNames, Str_SectionTopic_ParamIniFN, '');
  //f_StateIniFile.FileName := ActIniFile.ReadString(Str_SectionName_FileNames, Str_SectionTopic_StateIniFN, '');

  Init(ActIniFile);
  CloseFile(ControlFile);
  //DeleteFile('default.fn');
end;


