var
  SubModIndex: integer;
begin
  {if value <> nil then
  begin}

  SubModName := Name;
  GlobMod := Model;
  fn_rate := Globmod.FOutputPath +'\'+ Name + '_rat.csv';
  fn_state := Globmod.FOutputPath +'\'+ Name + '_dat.csv';

