(******************************************************************
CLASS   TSubmodel
METHOD  ExternVCreate
PURPOSE Method for creating and and initialising a TExternV variable
INPUT   Name, Units: string;
        ExV: TexValue;
        var ExternV: TexternV
*******************************************************************)

procedure TSubModel.ExternVCreate(Name, Units: string; ExV: TexValue;
  var ExternV: TexternV);

begin
  if ExternV = nil then begin
      ExternV := TexternV.create(name, Units, ExV);
      ExternVStrList.Add(name);
      ExternVStrList.objects[ExternVStrList.indexof(name)] := externV;
    end;
  {showmessage(externVStrList.commatext);}
end;


(******************************************************************
CLASS   TSubmodel
METHOD  ExternVInit
PURPOSE Setting pointers of external variables
INPUT   model: Tmod
*******************************************************************)

procedure TSubModel.ExternVInit(model: Tmod);

var
  i, j, index: Integer;
  SubMod: TSubModel;
  State: TState;
  Variable: TPar;
  ExternV: TExternV;
  par: TPar;
  success: boolean;

begin
  //for all external variables of the submodel do...
  for i := 0 to ExternVStrlist.Count - 1 do begin
      success := false;
      ExternV := TExternV(ExternVStrlist.objects[i]);
      {showmessage(model.weatherfile.FirstLine.commatext);}

      //is external variable stored within weather file?
      index := model.weatherfile.FirstLine.IndexOf(ExternV.name);

      //yes, external variable is stored in weather file
      if (index <> -1) then begin
          par := Tpar(model.weatherfile.firstline.objects[index]);
          ExternV.SetPointer(@par.v);
          ExternV.Source := model.weatherfile.filename;
          success := true;
        end
      //no, external variable is not stored in weather file
      else begin
          for j := 0 to model.SubModStrList.Count - 1 do begin
              // check all submodels except the calling submodel itself
              if j <> model.SubModStrList.IndexOf(self.SubModName) then begin
                  SubMod := TSubModel(model.SubModStrList.objects[j]);

                  //is external variable stored in state variables list?
                  index := subMOd.StateStrList.IndexOf(ExternV.Name);
                  if (index <> -1) then begin
                      State := Tstate(subMOd.StateStrList.objects[index]);
                      if ExternV.Ex = stateField then
                        ExternV.SetPointer(@State.v)
                      else
                        ExternV.SetPointer(@state.c);
                      ExternV.source := SubMod.name;
                      success := true;
                    end;

                  //if not successful, try searching variables list
                  if not success then begin
                      index := subMod.VarStrList.IndexOf(ExternV.Name);
                      if (index <> -1) then begin
                          Variable := TPar(subMOd.VarStrList.objects[index]);
                          ExternV.SetPointer(@Variable.v);
                          ExternV.source := SubMod.name;
                          success := true;
                        end;
                    end;

                  //if not successful, try searching parameters list
                  if not success then begin
                      index := subMod.ParStrList.IndexOf(ExternV.Name);
                      if (index <> -1) then begin
                          Variable := TPar(subMOd.ParStrList.objects[index]);
                          ExternV.SetPointer(@Variable.v);
                          ExternV.source := SubMod.name;
                          success := true;
                        end;
                    end;
                end;
            end;
        end;

      //no success at all
      if Success = false then begin
          ExternV.Source := 'not found';
          ShowMessage('Error on initialisation of interface, Parameter: ' + ExternV.Name + '  SubModel:'+self.name);
        end;
    end;

end;


(******************************************************************
CLASS   TSubmodel
METHOD  AddSimValueToDataSeries
PURPOSE Adding simulated values to corresponding measured data
*******************************************************************)

procedure TSubModel.AddSimValueToDataSeries;

var
  i, ListPos: integer;
  ActSeries: TMeasList;
  ActMeas: TMeasValue;
  ActState: TState;
  ActVar: TVar;

begin
  for I := 0 to DataList.Count - 1 do begin
      ActSeries := TMeasList(DataList.objects[i]);
      if ActSeries.ActPos <= ActSeries.count - 1 then begin
          ActMeas := TmeasValue(ActSeries.items[ActSeries.ActPos]);
          if (ActMeas.date <= GlobTime.v) and
            (ActMeas.date > ActSeries.LastDate) then begin
              ActSeries.LastDate := GlobTime.v;
              if ActSeries.actPos < ActSeries.count then
                inc(ActSeries.actPos);
              ListPos := StateStrList.indexof(ActSeries.name);
              if ListPos <> -1 then begin
                  ActState := Tstate(StateStrList.objects[ListPos]);
                  ActMeas.sim := ActState.V;
                  ActSEries.SumSqr := ActSEries.SumSqr + sqr(ActMeas.sim - ActMeas.meas);
                end else begin
                  ListPos := VarStrList.indexof(ActSeries.name);
                  if ListPos <> -1 then begin
                      ActVar := TVar(VarStrList.objects[ListPos]);
                      ActMeas.sim := ActVar.V;
                      ActSEries.SumSqr := ActSEries.SumSqr + sqr(ActMeas.sim - ActMeas.meas);
                    end;
                end;
            end;
        end;
    end;
end;


