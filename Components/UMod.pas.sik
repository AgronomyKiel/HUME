begin
  //for all data pairs do...
  for I := 0 to DataList.Count - 1 do begin
      ActSeries := TMeasList(DataList.objects[i]);
      ActSeries.WriteToFile(GlobMod.FOutputPath + '/' + ActSeries.name + '_1_1.csv');
    end;
end;


