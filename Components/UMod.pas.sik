(******************************************************************
CLASS   TMod
METHOD  init
PURPOSE Initialize state, parameter and weather files; init time
        settings; resort submodels
*******************************************************************)

procedure TMod.init;

{const
  SectionName = 'FileNames';}

var
  StateInifilefn: string;
  ParamIniFilefn: string;
  WeatherFilefn: string;
  SubName: string;
  f     : TextFile;
  i, NewIndex, OldIndex: integer;
  subMod: TSubModel;
  TimeStep: real;
  error: boolean;
  TempString: TStringlist;

begin
  // change to application directory
  if self.fApplicationPath <> '' then begin
    chdir(self.fApplicationPath);
  end;

  // read state Ini file name and create if not existing
  StateInifilefn := ActIniFile.ReadString(Str_SectionName_FileNames, Str_SectionTopic_StateIniFN, '');
  if fileExists(StateInifilefn) = false then begin
      if StateIniFileFN = '' then begin
        StateIniFileFN := extractFiledir(application.exename)+'\State.ini';
        ActIniFile.WriteString(str_sectionName_FileNames, str_sectiontopic_StateIniFN,StateIniFileFN);
      end;
      assignfile(f, StateInifilefn);
      rewrite(f);
      writeln(f);
      close(f);
      {ShowMessage('IniFile ' + StateInifilefn + ' does not exist');
      ShowMessage('Model initalisation failed !');
      exit;}
  end;

  // read parameter Ini file name and create if not existing
  ParamInifilefn := ActIniFile.ReadString(Str_SectionName_FileNames, Str_SectionTopic_ParamIniFN, '');
  if fileExists(ParamInifilefn) = false then begin
      if ParamIniFileFN = '' then begin
        //ParamIniFileFN := extractFiledir(application.exename)+'\Param.ini';
        ActIniFile.WriteString(str_sectionName_FileNames, str_sectiontopic_ParamIniFN, ParamIniFileFN);
      end;
      assignfile(f,ParamInifilefn);
      rewrite(f);
      writeln(f);
      close(f);
      {ShowMessage('IniFile ' + ParamInifilefn + ' does not exist');
      ShowMessage('Model initalisation failed !');
      exit;}
    end;

  // read weather file name and create if not existing
  WeatherFilefn := ActIniFile.ReadString(Str_SectionName_FileNames, Str_SectionTopic_WeatherFileFN, '');
  if fileExists(WeatherFilefn) = false then begin
    ShowMessage('WeatherFile ' + WeatherFilefn + ' does not exist');
    exit;
  end;

  //init weather data file
//  if fileExists(WeatherFilefn) then
//    WeatherFile.Init(WeatherFileFN);

  //init state and parameter ini files
  StateInifile.init(StateInifileFn);
  ParamInifile.init(ParamInifileFn);

  //init weather data file again (?)
  If Fileexists(WeatherFileFN) then begin
    WeatherFile.init(WeatherFileFN);

    TempString:= TStringList.Create;                        // Treue
    TempString.CommaText:= WeatherFile.GetFirstLine;        // Treue
    FirstWeatherData:= StrToInt(TempString.Strings[0]);    // Treue
    TempString:= TStringList.Create;                        // Treue
    TempString.CommaText:= WeatherFile.GetLastLine;         // Treue
    LastWeatherData:= StrToInt(TempString.Strings[0]);     // Treue

    WeatherFile.GoTop;
  end;

  //init time settings
  FStartTime := Inifile.ReadFloat(Str_SectionName_TimeInit, Str_SectionTopic_SimStart, 0, error);
  FEndTime := Inifile.ReadFloat(Str_SectionName_TimeInit, Str_SectionTopic_SimEnd, 365, error);
  TimeStep := IniFile.ReadFloat(Str_SectionName_TimeInit, Str_SectionTopic_TimeStep, 1, error);
  if time = nil then
    Time := TState.create('Time', '[d]', FStartTime, TimeStep)
  else begin
      time.v := FStartTime;
      time.C := Timestep;
    end;
  ModelEnd := false;

  // resort string list of submodels
  SubModStrList.Sort;
  for i := 0 to SubModStrList.count - 1 do begin
      SubName := SubModStrList.strings[i];
      SubMod := TSubModel(SubModStrList.objects[i]);
      OldIndex := SubModStrList.indexof(SubName);
      NewIndex := SubMod.CompIndex;
      if NewIndex <> -1 then
        SubModStrList.Exchange(OldIndex, NewIndex);

    end;
end;


(******************************************************************
CLASS   TMod
METHOD  InitAllsubMods
PURPOSE Call inititalisation methods of sub-models
*******************************************************************)

procedure TMod.InitAllsubMods;
var
  i: Integer;
  SubMod: TSubModel;
begin
  for I := 0 to SubModStrList.Count - 1 do begin
      SubMod := TSubModel(SubModStrList.objects[i]);
      SubMod.Init(self);
    end;
end;


(******************************************************************
CLASS   TMod
METHOD  Create
PURPOSE Calls inherited TGraphicControl.create and  initializes
        properties, lists and files
*******************************************************************)

constructor TMod.Create(AOwner: TComponent);

var
  i, NewIndex, OldIndex: integer;
  subMod: TSubModel;
  SubName: string;

begin
  // call inherited create contructor (TGraphicControl)
  inherited create(AOwner);

  // set style properties
  ControlStyle := ControlStyle + [csReplicatable];
  Width := 80;
  Height := 30;
  Canvas.Pen.Color := CLWhite;
  Canvas.Pen.Mode := pmCopy;
  Canvas.Pen.Width := 2;
  Canvas.Brush.Color := clred;
  Canvas.Brush.Style := bsSolid;
  Canvas.Font.Size := 12;

  // initialize several properties, lists and files
  SubModStrList := TStringList.create;
  FIniFiles := TStringList.create;
  AllMeasVal := TMeasList.Create('All', '[-]');
  SelParList := TStringList.Create;
  Separator := ',';

  // initialize model time settings
  Time := TState.create('Time', '[d]', 0.0, 1.0);
  FTimeStep := 1.0;
  FStartTime := StrToDateTime('01.01.1999');
  FEndTime := StrToDateTime('31.12.1999');

  // initialize several properties, lists and files
  Cursor := CrHandPoint;
  Reg_fn := 'regression.dat';
  FLMOptions := TMarquardOptions.create;
  SensOpt := TSensitivityOptions.create;
  WeatherFile := TTextfileH.create;
  ContOutput := true;
  FinalOutput := false;

  // re-sort list of submodels
  for i := 0 to SubModStrList.count - 1 do begin
      SubName := SubModStrList.strings[i];
      SubMod := TSubModel(SubModStrList.objects[i]);
      OldIndex := SubModStrList.indexof(SubName);
      NewIndex := SubMod.CompIndex;
      if NewIndex <> -1 then
        SubModStrList.Exchange(OldIndex, NewIndex);
    end;

  // sets smallest measured value accepted in Optimization
  FMinLegalValue := 1E-999;

  // set section names (used in ini files)
  FStr_SectionNameMeasurementFiles  := 'MeasurementFiles';
  Fstr_SectionNameOutPutFiles       := 'OutPutFiles';
  FStr_SectionName_FileNames        := 'FileNames';
  Str_SectionName_TimeInit          := 'TimeInit';
  Str_SectionTopic_SimStart         := 'Startzeit';
  Str_SectionTopic_SimEnd           := 'Endzeit';
  Str_SectionTopic_TimeStep         := 'TimeStep';
  Str_SectionTopic_ParamIniFN       := 'ParamIniFN';
  Str_SectionTopic_WeatherFileFN    := 'WeatherFileFN';
  Str_SectionTopic_StateIniFN       := 'StateIniFN';


  {If fileexists(ControlFileFn) = false then begin
    ControlFileFN := GetCurrentDir+'\default.fn';
    assignfile(controlfile, controlfileFN);
    rewrite(ControlFile);
    writeln(controlFile, GetCurrentDir+'\default.ini');
    closefile(Controlfile);
    Set_ControlFileFN(ControlFileFN);
  end;  }


  {name := 'model';}

  // initialize state and parameter files
  StateIniFile := TMyIniFile.create;
  ParamIniFile := TMyInifile.create;

end;


(******************************************************************
CLASS   TMod
METHOD  WriteAllNames
PURPOSE For all submodels write state and rate names to output files
*******************************************************************)

procedure TMod.WriteAllNames;

var
  i: integer;
  SubMod: TSubModel;
begin
  // for all submodels do...
  for i := 0 to SubmodStrlist.Count - 1 do begin
      SubMod := TSubModel(SubModStrList.objects[i]);
      if SubMod.WriteTofile then begin
          //writes state and rate names of specific submodel to _dat.csv / _rat.csv files
          SubMod.WriteStateName(SubMod.f_state, SubMod.fn_state, Time);
          SubMod.WriteRateName(SubMod.f_rate, SubMod.fn_rate, Time);
        end;
    end;
end;


