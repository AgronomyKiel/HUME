(******************************************************************
CLASS   TSubmodel
METHOD  Create
PURPOSE Creates TSubModel according to TComponent.create
INPUT   AOwner: TComponent
COMMENT The TSubmodel class is derived from the TGraphicControl class
*******************************************************************)

constructor TSubModel.Create(AOwner: TComponent);
var
  actseries: TMeasList;
  Date, x: real;
  MeasValue: TMeasValue;
begin
  //calls inherited TGraphicControl.create
  inherited create(AOwner);

  //sets TGraphicControl style properties
  Canvas.brush.Color := ClGreen;
  Canvas.Font.Size := 12;
  ControlStyle := ControlStyle + [csReplicatable];
  Width := 100;
  Height := 50;
  Canvas.Pen.Color := clblack;
  Canvas.Pen.Mode := pmCopy;
  Canvas.Pen.Width := 2;
  Canvas.Brush.Style := bsSolid;
  Canvas.Font.Color := clWhite;

  //Initiates lists for state variables, parameters, external values and measured data series
  WriteTofile := true;
  StateSTrList := TStringList.create;
  StateSTrList.Sorted := true;
  StateStrlist.Duplicates := dupignore;
  ParStrList := TstringList.create;
  ParStrList.Sorted := true;
  ParStrList.Duplicates := dupignore; // adding duplicates to the sorted list will trigger an LListError exception
  ExternVStrList := TstringList.create;
  ExternVStrList.sorted := true;
  ExternVStrList.Duplicates := dupignore;
  VarStrList := TstringList.create;
  VarStrList.Sorted := true;
  VarStrList.Duplicates := dupignore;
  ConstStrList := TStringList.create;
  ConstStrList.Sorted := true;
  ConstStrList.Duplicates := dupignore;
  DataList := TStringList.Create; // List of measured data series

  //calls TGraphicControl.activate (virtual)
  Activate;

  Cursor := CrHandPoint;
  compindex := -1;
  FMeasValues := TTextFileH.create;
  CreateAll;
end;


(******************************************************************
CLASS   TSubmodel
METHOD  Init
PURPOSE Initialisation method for TSubmodem
INPUT   var GlobMod: TMod
COMMENT Is being called on creation of application form and on run of simulation
*******************************************************************)

procedure TSubModel.Init(var GlobMod: TMod);

var
  i, j, line: integer;
  State: TState;
  Param: Tpar;
  variable: TVar;
  NewSeries, series: TMeasList;
  error: boolean;
  fn_meas, fn_meas_2, Namestr, Unitstr: string;
  ActDataList: TStringList;
  ActMeas: TMeasValue;
  ActSeries: TMeasList;
  value: real;
  Date, x: real;
  MeasValue: TMeasValue;
  defaultname : string;

begin
  ParIniF := Globmod.ParamInifile;
  StateIniF := Globmod.StateIniFile;
  GlobTime := GlobMod.Time;

  // (Re)initialization of all state variables
  StateSTrList.Sorted := false;
  for I := 0 to self.StateStrList.Count - 1 do begin
      State := TState(StateStrList.Objects[i]);
      StateStrList.Strings[i] := State.name;
      State.c := 0.0; //  At the beginning the rate of change equals 0 for all state variables
      if State.ReadFromFile and (State.name <> '') then begin
          value := GlobMod.StateIniFile.ReadFloat(SubModName, State.name, 0.0, error);
          State.v := value;
        end;
      if error then begin
          GlobMod.StateIniFile.WriteFloat(SubModName, State.name, State.DefaultValue);
          {ShowMessage('Error on initialization of state variables');}
        end;
    end;
  StateStrList.Sort;
  StateSTrList.Sorted := true;

  // (Re)initialization of all parameters
  ParStrList.Sorted := false;
  for I := 0 to ParStrList.Count - 1 do begin
      Param := TPar(ParStrList.Objects[i]);
      ParStrList.Strings[i] := Param.Name;
      if Param.SelForOpt = false then { Read values only if not selected for optimization ! }
        Param.v := GlobMod.ParamIniFile.ReadFloat(SubModName, Param.name, Param.DefaultValue, error)
        {else showMessage(GlobMod.ParamInifile.Filename+Separator+Param.n+Separator+FloatToStr(Param.v))};
      if error then begin
          GlobMod.ParamIniFile.WriteFloat(SubModName, Param.name, Param.DefaultValue);
          {ShowMessage('Error on initialization of parameters');}
        end;
    end;
  ParStrList.sort;
  ParStrList.sorted := true;

  // (Re)initialization of all variables
  VarStrList.sorted := false;
  for I := 0 to self.VarStrList.Count - 1 do begin
      Variable := TVar(VarStrList.Objects[i]);
      VarStrList.strings[i] := Variable.Name;
      if Variable.ReadFromFile then begin
          Variable.v := GlobMod.StateIniFile.ReadFloat(SubModName, Variable.name, Variable.DefaultValue, error)
          {else showMessage(GlobMod.ParamInifile.Filename+Separator+Param.n+Separator+FloatToStr(Param.v))};
          if error then begin
              GlobMod.ParamIniFile.WriteFloat(SubModName, Variable.name, Variable.DefaultValue);
            end;
          {ShowMessage('Error on initialization of variables');}
        end else begin
          Variable.v := 0.0;
        end;
    end;
  VarStrLIst.sort;
  VarStrList.sorted := true;

  //reads filenames of measurement and output files from main Ini-file
  fn_meas := GlobMod.ActIniFile.ReadString(GlobMod.Str_SectionName_MeasurementFiles, SubModName, '');
//  fn_meas_2 := GlobMod.ActIniFile.ReadString(GlobMod.str_SectionName_MeasurementFiles, SubModName + '_2', '');

  defaultName :=  ExtractFileName(globmod.ActIniFile.FileName);
  delete(defaultname, pos('.', defaultname),4);
  defaultname := GlobMod.FOutputPath+'\'+defaultname+'_'+SubModname; 
  fn_state := GlobMod.ActIniFile.ReadString(GlobMod.str_SectionName_OutputFiles, SubModName, Defaultname) + '_dat.csv';
  fn_rate := GlobMod.ActIniFile.ReadString(GlobMod.str_SectionName_OutputFiles, SubModName, Defaultname) + '_rat.csv';

  //opens measurement data files and put data into list of data series
  //#TS#034# redundancy with following section
  if FileExists(fn_meas) then begin
      if FmeasValues = nil then
        FMeasValues := TTextFileH.create
      else begin
        FMeasValues.init(fn_meas);
      end;
      SomethingMeasured := true;
      with FMeasValues do begin
          for i := 1 to FirstLine.Count - 1 do begin
              Namestr := FirstLine.Strings[i];
              Unitstr := UnitLine.strings[i];
              if DataList.IndexOf(NameStr) = -1 then begin
                  NewSeries := TMeasList.Create(Namestr, Unitstr);
                  DataList.AddObject(NameStr, NewSeries);
                end;
            end;
          for i := 0 to DataList.Count - 1 do begin
              ActSeries := TMeasList(DataList.objects[i]);
              Actseries.Lastdate := GlobMod.Time.v;
              ActSeries.SumSqr := 0.0;
              ActSeries.slope := 0.0;
              ActSeries.intercept := 0.0;
              ActSeries.r2 := 0.0;
            end;

          GoTop;
          for line := 1 to FMeasValues.n_Line do begin
              NextLine;
              for i := 0 to DataList.Count - 1 do begin
                  date := FmeasValues.getIndexValue(0);
                  x := FmeasValues.getValue(TMeasList(DataList.objects[i]).Name);
                  if (x > GlobMod.MinLegalValue) and (Date >= GlobMod.FStartTime) and (Date <= GlobMod.FEndTime) then begin
                  //if (x > GlobMod.MinLegalValue) and (Date < GlobMod.FEndTime) then begin
                      MeasValue := TMeasValue.create(Date, x, GlobMod.MinLegalValue);
                      TMeasList(DataList.Objects[i]).Add(MeasValue);
                    end;
                end;
            end;
        end;
    end else begin
      SomethingMeasured := false;

      if FileExists(fn_meas) and (fn_meas <> '') then
        ShowMessage('Measurementfile ' + fn_meas + 'of ' + self.name + ' is specified but does not exist')
    end;

  //opens measurement data files and put data into list of data series
  //#TS#034# redundancy with previous section
  if FileExists(fn_meas_2) then begin
      somethingmeasured := true;
      if FmeasValues_2 = nil then
        FMeasValues_2 := TTextFileH.create
      else begin
        FMeasValues_2.init(fn_meas_2);
      end;
      SomethingMeasured := true;
      with FMeasValues_2 do begin
          for i := 1 to FirstLine.Count - 1 do begin
              Namestr := FirstLine.Strings[i];
              Unitstr := UnitLine.strings[i];
              if DataList.IndexOf(NameStr) = -1 then begin
                  NewSeries := TMeasList.Create(Namestr, Unitstr);
                  DataList.AddObject(NameStr, NewSeries);
                end;
            end;
          for i := 0 to DataList.Count - 1 do begin
              ActSeries := TMeasList(DataList.objects[i]);
              Actseries.Lastdate := GlobMod.Time.v;
              ActSeries.SumSqr := 0.0;
              ActSeries.slope := 0.0;
              ActSeries.intercept := 0.0;
              ActSeries.r2 := 0.0;
            end;

          GoTop;
          for line := 1 to FMeasValues_2.n_Line do begin
              NextLine;
              for i := 0 to DataList.Count - 1 do begin
                  date := FmeasValues_2.getIndexValue(0);
                                if (x > GlobMod.MinLegalValue) and (Date >= GlobMod.FStartTime) and (Date <= GlobMod.FEndTime) then begin
                  x := FmeasValues_2.getValue(TMeasList(DataList.objects[i]).Name);
                  //if (x > GlobMod.MinLegalValue) and (Date < GlobMod.FEndTime) then begin
                      MeasValue := TMeasValue.create(Date, x, GlobMod.MinLegalValue);
                      TMeasList(DataList.Objects[i]).Add(MeasValue);
                    end;
                end;
            end;
        end;
    end else begin

      if FileExists(fn_meas_2) and (fn_meas_2 <> '') then
        ShowMessage('Measurementfile ' + fn_meas_2 + 'of ' + self.name + ' is specified but does not exist')
    end;

  //calls TGraphicControl.activate (virtual)
  Activate;

end;


