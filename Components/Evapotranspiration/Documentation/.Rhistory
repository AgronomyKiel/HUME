#| label: CalcGamma
#| echo: FALSE
#| message: FALSE
#| warning: FALSE
c_p <- 1005 # specific heat of air at constant pressure [J/kg/K]
lambda_v <- 2.477 * 1E6 # latent heat of vaporisation of water [J/kg]
MW_ratio <- 0.622 # ratio of the molecular weight of water to the molecular weight of dry air
gamma <- function(P, Temp){
return(c_p * P / (lambda_v * MW_ratio))
}
gamma_value <- gamma(1013, 10)
gamma_value
0.000662*1005
gamma_value
