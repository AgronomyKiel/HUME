#| label: fig-VapourPressureDeficit
#| echo: FALSE
#| message: FALSE
#| warning: FALSE
#| fig-cap: Vapour pressure values for 100 and 60% relative humidity and vapour pressure deficit as a function of temperature from the Tetens-equation
#| fig-width: 12
#| fig-height: 6
df100 <- expand.grid(T = seq(-10, 40, 1))
df60 <- df100
df_es_ea <- df100
df100$e <- sat_vap_press_f(df100$T)
df100$RH <- "100%"
df60$e <- 0.6*df100$e
df60$RH <- "60%"
df_es_ea$e <- df100$e - 0.6*df100$e
df_es_ea$RH <- "es-ea"
df <- rbind(df100, df60, df_es_ea)
illu <- df# %>% filter(VapourPressure != "es_ea")
p <- ggplot(data=illu, aes(x=T, y=e,color=RH))
p <- p + geom_line(size=1)
p <- p + ylab ("Vapour pressure [hPa]") + xlab("Temperature [°C]")
p <- p + scale_color_brewer(palette = "Set1")
p <- p + theme_bw(base_size = 20)
p
#| label: CalcGamma
#| echo: FALSE
#| message: FALSE
#| warning: FALSE
c_p <- 1005 # specific heat of air at constant pressure [J/kg/K]
lambda_v <- 2.477 * 1E6 # latent heat of vaporisation of water [J/kg]
MW_ratio <- 0.622 # ratio of the molecular weight of water to the molecular weight of dry air
gamma <- function(P, Temp){
return(c_p * P / (lambda_v * MW_ratio))
}
gamma_value <- gamma(1013, 10)
gamma_value
0.000662*1005
gamma_value
