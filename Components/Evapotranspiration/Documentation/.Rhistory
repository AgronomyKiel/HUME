#| label: fig-rc_f
#| echo: FALSE
#| message: FALSE
#| warning: FALSE
#| fig-align: center
#| fig-cap: Canopy resistance rc as a function of leaf area index according to the empirical model of Stockle
#| fig-width: 12
#| fig-height: 6
#| fig-pos: h
relRc0Inc_CO2 <- 0.25
CiThreshold <- 380
LAI <- seq(0, 6, 0.1)
df <- expand.grid(LAI = LAI, CO2pp = seq(350, 500, 50))
df$rc0 <- 50
relDeltaCi <- function(CO2pp, CiThreshold){
return((CO2pp - CiThreshold)/CiThreshold)
}
rc_0 <- function (Plant_rc0, relDeltaCi, relRc0Inc_CO2){
return(Plant_rc0*(1+relDeltaCi*relRc0Inc_CO2))
}
df$relDeltaCi <- Vectorize(FUN = relDeltaCi) (df$CO2pp, CiThreshold)
df$rc0 <- Vectorize(FUN = rc_0) (50, df$relDeltaCi, relRc0Inc_CO2)
df$rcs <- Vectorize(FUN =  rc_f) (df$rc0, df$LAI)
m <- NULL
m <-ggplot(data=df, aes(x=LAI, y=rcs, color=CO2pp))
m <- m + geom_line(size=1)
m <- m + ylab ("rc [s/m]") + xlab("LAI [-]")
m <- m + scale_color_brewer(palette = "spectrum")
m <- m + theme_bw(base_size = 18)
m
illu <- df
illu$CO2pp <- as.factor(illu$CO2pp)
m <- NULL
m <-ggplot(data=illu, aes(x=LAI, y=rcs, color=CO2pp))
m <- m + geom_line(size=1)
m <- m + ylab ("rc [s/m]") + xlab("LAI [-]")
m <- m + scale_color_brewer(palette = "spectrum")
m <- m + theme_bw(base_size = 18)
m
