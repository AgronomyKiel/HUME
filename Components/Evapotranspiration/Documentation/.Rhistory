if (length(param_nodes) == 0) return("")
paste(
sapply(param_nodes, function(p) {
pname <- xml_attr(p, "name")
ptext <- xml_text(p)
paste0(pname, ": ", trimws(ptext))
}),
collapse = "; "
)
}),
stringsAsFactors = FALSE
)
