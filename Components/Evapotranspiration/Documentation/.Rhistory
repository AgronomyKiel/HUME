}
rc_0 <- function (Plant_rc0, relDeltaCi, relRc0Inc_CO2){
return(Plant_rc0*(1+relDeltaCi*relRc0Inc_CO2))
}
df$relDeltaCi <- Vectorize(FUN = relDeltaCi) (df$CO2pp, CiThreshold)
