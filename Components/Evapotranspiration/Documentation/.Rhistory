# Find the <class> node for TPenMonteith
class_node <- xml_find_first(doc, './/class[@name="TPenMonteith"]')
# Find all <function> nodes inside this class
fun_nodes <- xml_find_all(class_node, ".//function")
# Extract detailed information
fun_df <- data.frame(
name = xml_attr(fun_nodes, "name"),
visibility = xml_attr(fun_nodes, "visibility"),
parameters = sapply(fun_nodes, function(fn) {
params <- xml_find_all(fn, ".//parameter")
paste(
sapply(params, function(p) {
pname <- xml_attr(p, "name")
ptype <- xml_attr(p, "type")
if (is.na(pname)) {
return(paste0("return: ", ptype))
} else {
return(paste0(pname, ": ", ptype))
}
}),
collapse = ", "
)
}),
summary = sapply(fun_nodes, function(fn) {
summary_node <- xml_find_first(fn, ".//devnotes//summary[not(starts-with(., '<param')) and not(starts-with(., '<returns'))]")
if (!is.na(summary_node)) xml_text(summary_node) else NA_character_
}),
param_docs = sapply(fun_nodes, function(fn) {
param_nodes <- xml_find_all(fn, ".//devnotes//summary[starts-with(., '<param')]")
paste(
sapply(param_nodes, function(p) gsub("^<param name=\"|\">|</param>$", "", xml_text(p))),
collapse = "\n"
)
}),
stringsAsFactors = FALSE
)
View(fun_df)
View(fun_df)
