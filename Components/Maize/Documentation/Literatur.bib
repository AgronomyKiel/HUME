@article{Rothardt.2023,
 abstract = {The combination of high post-harvest soil mineral N, low N uptake in autumn/winter and percolation causes a serious risk of N losses in common crop rotations in Central-Europe. Consequences may be eutrophication of water bodies and indirect greenhouse gas emissions. One approach to synchronize N-supply and -demand would be to control microbial immobilization induced by organic matter incorporation. In order to examine the extent to which this effect varies with different amendments in field-scale, the incorporation of crop residues of winter oilseed rape, faba beans and winter wheat were compared with the application of sawdust. Measurements were supplemented with model-derived parameters and analyzed for the impact on the autumn/winter N-dynamics. We could show that the suggested mechanism significantly reduced autumn net mineralization in top soil. As expected, the reduction was larger with increasing C:N ratio of the amendment. However, the impact on N leaching out of the reach of crop roots ({\textgreater}120 cm) was low. Field observations, modeling processes and a theoretical amendment assessment indicated accumulation of resistant organic matter under the given environmental conditions. Consequently, the stabilized carbon has a rather long-term effect on nutrient dynamics. In conclusion, to incorporate the preceding crop residues is still the best option to mitigate post-harvest N losses and to improve soil health with minimal crop management efforts.},
 author = {Rothardt, Steffen and Kage, Henning},
 year = {2023},
 title = {Model-based assessment of biomass incorporation to mitigate nitrogen losses from arable fields in Central Europe},
 url = {https://www.frontiersin.org/articles/10.3389/fagro.2023.1155187/full},
 keywords = {Carbon sequestration;N-leaching;Organic amendments;plant-soil-atmosphere model;Residue management;soil health},
 pages = {25},
 volume = {5},
 issn = {2673-3218},
 journal = {Frontiers in Agronomy},
 doi = {10.3389/fagro.2023.1155187}
}


@article{Rose.2023,
 abstract = {Recently the application of spectral reflection data for the prediction of crop parameters for applications in precision agriculture, such as green area index (GAI), total aboveground dry matter (DM), and total aboveground nitrogen content (N content) increases. However, the usability of vegetation indices (VI) for the prediction of crop parameters is strongly limited by the fact that most VI calibrations are only valid for specific crops and growth periods. The results of the presented study based on the differentiation of primary (main driver of the reflectance signal) and secondary (not directly related to reflectance signal) crop parameters. For GAI prediction, a universal (without crop-specific parametrization) simple ratio vegetation index (SR) provided good calibration (R2 adj. = 0.90, MAE = 0.32, rMAE = 22{\%}) and evaluation results (MAE = 0.33, rMAE = 18{\%}). The disentanglement of primary and secondary traits allowed the development of a functional two-step model for the estimation of the N content during vegetative growth (MAE = 19.2{\&}nbsp;g N m$-$1, rMAE = 44{\%}). This model was based on fundamental, crop-specific relationships between the crop parameters GAI and N content. Additionally, an advanced functional approach was tested enabling the whole-season prediction of DM and confirming a reliable GAI estimation throughout the whole growing season (R2 = 0.89--0.93).},
 author = {Rose, Maren and Rose, Till and Kage, Henning},
 year = {2023},
 title = {Spectral reflection and crop parameters: can the disentanglement of primary and secondary traits lead to more robust and extensible prediction models?},
 url = {https://link.springer.com/article/10.1007/s11119-022-09961-9},
 pages = {607--626},
 volume = {24},
 number = {2},
 issn = {1385-2256},
 journal = {Precision Agriculture},
 doi = {10.1007/s11119-022-09961-9},
 file = {Rose, Rose et al. 2023 - Spectral reflection and crop parameters:Attachments/Rose, Rose et al. 2023 - Spectral reflection and crop parameters.pdf:application/pdf}
}


