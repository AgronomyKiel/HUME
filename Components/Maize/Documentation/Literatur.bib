 url = {https://www.mdpi.com/2072-4292/14/18/4525},
 keywords = {Catch crops;NDVI;Parrot Sequoia;pure and mixed canopies;Remote sensing;sensor calibration},
 pages = {4525},
 volume = {14},
 number = {18},
 issn = {2072-4292},
 journal = {Remote Sensing},
 doi = {10.3390/rs14184525},
 file = {Holzhauser, R{\"a}biger et al. 2022 - Estimation of Biomass and N:Attachments/Holzhauser, R{\"a}biger et al. 2022 - Estimation of Biomass and N.pdf:application/pdf}
}


