 author = {Wang, Qingsuo and Sun, Dongbao and Hao, Hong and Zhao, Xuejiao and Hao, Weiping and Liu, Qiong},
 year = {2015},
 title = {Photosynthetically active radiation determining yields for an intercrop of maize with cabbage},
 pages = {32--40},
