 journal = {Journal of Soil and Water Conservation},
 file = {Paul W. Unger, Merle F. Vigil 1998 - Cover crop effects on soil:Attachments/Paul W. Unger, Merle F. Vigil 1998 - Cover crop effects on soil.pdf:application/pdf}
}


