@article{Koehler.2022,
 abstract = {Although the coordination between stomatal closure and aboveground hydraulics has extensively been studied, our understanding of the impact of belowground hydraulics on stomatal regulation remains incomplete. Here, we investigated whether and how the water use of maize (Zea mays L.) varied under hydraulically contrasting soil textures. Our hypothesis is that a textural-specific drop in the hydraulic conductivity is associated with a distinct decrease in transpiration during soil drying. Maize plants were grown in contrasting soil textures (sand, sandy loam, loam) and exposed to soil drying. We measured the relationships between transpiration rate, soil water content as well as soil and leaf water potential. We used a soil-plant hydraulic model to reproduce the experimental observations and infer the hydraulic conductance of the soil-plant system during soil drying. We observed the impact of soil texture on plant response to soil drying in various relationships. The soil water potentials at which transpiration decreased were more than one order of magnitude more negative in loam than in sand. The soil-plant conductance decreased not only abruptly but also at less negative soil water potentials in sand than in sandy loam or loam. Stomata closed at less negative leaf water potentials in sand than in loam. The model predictions matched well the experimental observations. The results elucidated that the critical soil water content and potential at which plants close stomata depends on the soil texture. These findings support our plea to include soil properties for understanding and predicting stomatal regulation during soil drying.},
 author = {Koehler, Tina and Moser, Daniel Sebastian and Botezatu, {\'A}kos and Murugesan, Tharanya and Kaliamoorthy, Sivasakthi and Zarebanadkouki, Mohsen and Bienert, Manuela D{\'e}sir{\'e}e and Bienert, Gerd Patrick and Carminati, Andrea and Kholov{\'a}, Jana and Ahmed, Mutez},
 year = {2022},
 title = {Going underground: Soil hydraulic properties impacting maize responsiveness to water deficit},
 url = {https://link.springer.com/article/10.1007/s11104-022-05656-2},
 keywords = {agriculture;Conservation;Ecology;Plant Physiology;Plant Sciences;Soil Science {\&}},
 pages = {43--58},
 volume = {478},
 number = {1},
 journal = {Plant and Soil},
 doi = {10.1007/s11104-022-05656-2},
 file = {Koehler, Moser et al. 2022 - Going underground:Attachments/Koehler, Moser et al. 2022 - Going underground.pdf:application/pdf}
}


