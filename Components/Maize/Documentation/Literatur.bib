@article{EusunHan.2020,
 abstract = {The scale of root quantification in research is often limited by the time required for sampling, measurement and processing samples. Recent developments in Convolutional Neural Networks (CNN) have made faster and more accurate plant image analysis possible which may significantly reduce the time required for root measurement, but challenges remain in making these methods accessible to researchers without an in-depth knowledge of Machine Learning. We analyzed root images acquired from three destructive root samplings using the RootPainter CNN-software that features an interface for corrective annotation for easier use. Root scans with and without non-root debris were used to test if training a model, i.e., learning from labeled examples, can effectively exclude the debris by comparing the end-results with measurements from clean images. Root images acquired from soil profile walls and the cross-section of soil cores were also used for training and the derived measurements were compared with manual measurements. After 200 minutes of training on each dataset, significant relationships between manual measurements and RootPainter-derived data were noted for monolith (R2=0.99), profile wall (R2=0.76) and core-break (R2=0.57). The rooting density derived from images with debris was not significantly different from that derived from clean images after processing with RootPainter. Rooting density was also successfully calculated from both profile wall and soil core images, and in each case the gradient of root density with depth was not significantly different from manual counts. Our results demonstrate that the proposed approach using CNN can lead to substantial reductions in root sample processing workloads, increasing the potential scale of future root investigations.{\#}{\#}{\#} Competing Interest StatementThe authors have declared no competing interest.},
 author = {{Eusun Han} and {Abraham George Smith} and {Roman Kemper} and {Rosemary White} and {John Kirkegaard} and {Kristian Thorup-Kristensen} and {Miriam Athmann}},
 year = {2020},
 title = {Digging roots is easier with AI},
 url = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/jpln.201900160},
 pages = {2020.12.01.397034},
 journal = {bioRxiv},
 doi = {10.1101/2020.12.01.397034}
}


@misc{Eurostat.2022,
 abstract = {Diese Tabelle beinhaltet die Fl{\"a}chen, die Erntemengen und den Feuchtigkeitsgehalt aller Formen von gr{\"u}n geerntetem Mais, einschlie{\ss}lich Gr{\"u}nmais, der direkt (unsiliert) als Futtermittel verbraucht wird sowie Mais mit ganzen Kolben (Korn, Spindel, Lieschbl{\"a}tter). Der geerntete Mais kann als Futtermittel, zur Silageherstellung oder zur Erzeugung von erneuerbaren Energien genutzt werden. Diesem Indikator liegen die Begriffe {\glqq}Anbaufl{\"a}che{\grqq}, {\glqq}Erntemenge{\grqq} und {\glqq}Feuchtigkeitsgehalt{\grqq} zugrunde. 1) Die {\glqq}Anbaufl{\"a}che{\grqq} entspricht: • vor der Ernte der Aussaatfl{\"a}che, • nach der Ernte der Aussaatfl{\"a}che ohne die nicht abgeerntete Fl{\"a}che (z. B. durch Naturkatastrophen vernichtete Fl{\"a}che, aus wirtschaftlichen Gr{\"u}nden nicht abgeerntete Fl{\"a}che, usw.). 2) Die {\glqq}Erntemenge{\grqq} entspricht der Erzeugung, mit deren Ernte im Jahr N begonnen wurde, auch wenn die Ernte im Jahr N+1 endet. Das Jahr N ist dabei das Bezugsjahr f{\"u}r die von Eurostat ver{\"o}ffentlichten Daten. 3) Um die Erzeugung der einzelnen Mitgliedstaaten leichter miteinander vergleichen zu k{\"o}nnen, ist die Ver{\"o}ffentlichung der nationalen Feuchtigkeitsgehaltwerte erforderlich. Nur die Erntemenge des EU-Aggregats wird mit einem EU-Standardfeuchtigkeitsgehalt ver{\"o}ffentlicht (65{\%}).

This table includes the area, production and humidity of all forms of maize harvested green grown mainly for silage. This includes green maize directly consumed by animals (without silage) and whole cobs (grain, rachis, husk) harvested for feedstuff or silage, as well as for renewable energy production. Maize harvested as grain and corn-cob-mix is excluded. This indicator uses the concepts of {\textquotedbl}area under cultivation{\textquotedbl}, {\textquotedbl}harvested production{\textquotedbl} and {\textquotedbl}humidity{\textquotedbl}. 1) The {\textquotedbl}area under cultivation{\textquotedbl} corresponds: • before the harvest, to the sown area; • after the harvest, to the sown area excluding the non-harvested area (e.g. area ruined by natural disasters, area not harvested for economic reasons, etc.) 2) The {\textquotedbl}harvested production{\textquotedbl} corresponds to the production for which harvesting started in year N, even though harvesting may finish in year N+1 (N is the reference year for data published by Eurostat). 3) In order to facilitate the comparisons of production figures between the Members States the figures have been converted from national humidity degrees into the standard EU humidity (65{\%}).

Ce tableau contient les superficies, les productions et l'humidit{\'e} pour toutes les formes de ma{\"i}s r{\'e}colt{\'e}es en vert et cultiv{\'e}es principalement pour l'ensilage. Sont compris le ma{\"i}s vert directement consomm{\'e} par les animaux (sans ensilage) et le ma{\"i}s en rafle enti{\`e}re (grain, rachis et spathes) r{\'e}colt{\'e} comme aliment pour les animaux et pour l'ensilage, ainsi que pour la production d'{\'e}nergie renouvelable. Cet indicateur utilise les notions de {\textquotedbl}superficie cultiv{\'e}e{\textquotedbl}, {\textquotedbl}production r{\'e}colt{\'e}e{\textquotedbl} et {\textquotedbl}humidit{\'e}{\textquotedbl}. 1) La {\textquotedbl}superficie cultiv{\'e}e{\textquotedbl} correspond: • avant la r{\'e}colte, {\`a} la superficie ensemenc{\'e}e; • apr{\`e}s la r{\'e}colte, {\`a} la superficie ensemenc{\'e}e, {\`a} l'exclusion de la superficie non r{\'e}colt{\'e}e (p. ex. superficie d{\'e}truite par des catastrophes naturelles, superficie non r{\'e}colt{\'e}e pour des raisons d'ordre {\'e}conomique, etc.). 2) La {\textquotedbl}production r{\'e}colt{\'e}e{\textquotedbl} correspond {\`a} la production pour laquelle la r{\'e}colte a commenc{\'e} au cours de l'ann{\'e}e N, m{\^e}me si elle peut se terminer au cours de l'ann{\'e}e N+1. L'ann{\'e}e N est d{\`e}s lors l'ann{\'e}e de r{\'e}f{\'e}rence pour les donn{\'e}es publi{\'e}es par Eurostat. 3) Afin de faciliter les comparaisons entre les productions des {\'E}tats membres, les chiffres en taux d'humidit{\'e} national ont {\'e}t{\'e} convertis en humidit{\'e} UE standard (14{\%}).},
 author = {Eurostat},
 date = {2022},
 title = {Green maize by area, production and humidity},
 publisher = {Eurostat},
 doi = {10.2908/TAG00101}
}


