doc <- read_xml(fn_xml_docu)
classes <- xml_find_all(doc, ".//class")
result <- data.frame(
class_name = xml_attr(classes, "name"),
devnotes_md = vapply(classes, function(class_node) {
dev <- xml_find_first(class_node, "./devnotes")
if (inherits(dev, "xml_missing")) return(NA_character_)
devnotes_xml_to_md(dev)
}, character(1)),
stringsAsFactors = FALSE
)
