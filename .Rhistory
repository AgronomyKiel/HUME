clean_ws <- function(x) gsub("\\s+", " ", trimws(x))
devnotes_xml_to_md <- function(devnotes_node) {
out <- character()
for (ch in xml_children(devnotes_node)) {
nm <- xml_name(ch)
if (nm == "para") {
text <- clean_ws(xml_text(ch))
out <- c(out, text, "")       # paragraph + blank line
} else if (nm == "list") {
# convert list items to bullet lines
items <- xml_find_all(ch, "./item/description")
if (length(items) > 0) {
bullets <- vapply(items, function(it) {
txt <- clean_ws(xml_text(it))
# if user used "**" after a number, ensure valid markdown (optionally)
# e.g. "1 **Emergence ..." -> "1 **Emergence** ..."
txt
}, character(1))
out <- c(out, paste0("- ", bullets), "")
} else {
# fallback: take plain text
out <- c(out, clean_ws(xml_text(ch)), "")
}
} else {
# generic fallback for any other inline node
out <- c(out, clean_ws(xml_text(ch)), "")
}
}
# drop trailing blank lines
while (length(out) && out[length(out)] == "") out <- out[-length(out)]
paste(out, collapse = "\n")
}
# produce Markdown string
devnotes_md <- devnotes_xml_to_md(devnode)
# Print to console (for checking)
cat(devnotes_md, sep = "\n\n")
