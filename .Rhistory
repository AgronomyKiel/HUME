fn <- "Components/Rootgrowth/Documentation/Weff.csv"
df.Weff <- read.csv(fn, header = TRUE, comment.char = "[", sep = ",", dec = ".")
names(df.Weff) <- c("Texture","BD", "Weff", "Weffrel")
num_cols <- names(df.Weff)[sapply(df.Weff, is.numeric)]
datatable(
df.Weff,
rownames = FALSE,
filter = "top",
options = list(
pageLength = 8,
autoWidth = TRUE,
scrollX = TRUE
),
callback = JS(
"table.on('init.dt', function() {",
"  var headerRows = $(table.table().header()).find('tr');",
"  if (headerRows.length > 1) {",
"    $(headerRows[1]).find('th').each(function(i) {",
"      if (i > 1) {",
"        $(this).html('');",
"      }",
"    });",
"  }",
"});"
)
) %>%
formatRound(columns = num_cols, digits = 3, dec.mark = ".")
#| label: setup-rooting-depth
#| warning: false
#| message: false
library(shiny)
library(dplyr)
library(ggplot2)
# Example assumptions:
# df.Weff has columns:
#   texture
#   bulkdensity
#   Weffrel
# parameters
df.Weff$texture <- df.Weff$Texture
df.Weff$bulkdensity <- df.Weff$BD
bzr_default <- 0.01
tsum_max <- 2000
texture_choices <- sort(unique(df.Weff$texture))
bd_choices      <- sort(unique(df.Weff$bulkdensity))
fluidRow(
column(
width = 3,
selectInput("tex1", "Texture class A", choices = texture_choices, selected = texture_choices[1]),
selectInput("bd1",  "Bulk density class A", choices = bd_choices, selected = bd_choices[1])
),
column(
width = 3,
selectInput("tex2", "Texture class B", choices = texture_choices, selected = texture_choices[min(2, length(texture_choices))]),
selectInput("bd2",  "Bulk density class B", choices = bd_choices, selected = bd_choices[min(2, length(bd_choices))])
),
column(
width = 3,
numericInput("zrmax", "zrmax", value = 200, min = 50, step = 10),
numericInput("bzr", "bzr", value = bzr_default, min = 0, step = 0.01)
),
)
renderPlot({
sel <- tibble(
texture = c(input$tex1, input$tex2),
bulkdensity = c(input$bd1, input$bd2),
group = c("A", "B")
)
plot_df <- sel %>%
left_join(df.Weff, by = c("texture", "bulkdensity")) %>%
tidyr::expand_grid(TSUM = seq(0, sum_max, by = 10)) %>%
mutate(
zrmax_eff = input$zrmax * Weffrel,
zr = pmin(zrmax_eff, TSUM * input$bzr * Weffrel),
label = paste0("Texture=", texture, ", BD=", bulkdensity, ", Weffrel=", round(Weffrel, 3))
)
ggplot(plot_df, aes(x = TSUM, y = zr, color = label)) +
geom_line(linewidth = 1.1) +
labs(
x = "Temperature sum (TSUM)",
y = "Rooting depth zr",
color = "Scenario"
) +
theme_minimal(base_size = 12)
})
#| label: rooting-depth-static-interactive
#| echo: false
#| message: false
#| warning: false
library(dplyr)
library(tidyr)
library(plotly)
library(crosstalk)
library(htmltools)
# Assumptions:
# df.Weff contains columns Texture, BD, Weffrel
bzr <- 0.01
zrmax <- 200
tsum_max <- 2000
plot_df <- df.Weff %>%
transmute(
texture = Texture,
bulkdensity = BD,
Weffrel = Weffrel
) %>%
filter(!is.na(texture), !is.na(bulkdensity), !is.na(Weffrel)) %>%
distinct() %>%
expand_grid(TSUM = seq(0, tsum_max, by = 10)) %>%
mutate(
zrmax_eff = zrmax * Weffrel,
zr = pmin(zrmax_eff, TSUM * bzr * Weffrel),
scenario = paste0(
"Texture=", texture,
", BD=", bulkdensity,
", Weffrel=", round(Weffrel, 3)
)
)
sd <- SharedData$new(plot_df, group = "rooting")
bscols(
widths = c(3, 9),
list(
filter_select("texture", "Texture class", sd, ~texture, multiple = TRUE),
filter_select("bd", "Bulk density class", sd, ~bulkdensity, multiple = TRUE)
),
plot_ly(
sd,
x = ~TSUM,
y = ~zr,
color = ~scenario,
type = "scatter",
mode = "lines",
hovertemplate = paste(
"TSUM=%{x}",
"<br>zr=%{y}",
"<extra>%{fullData.name}</extra>"
)
) %>%
layout(
title = "Effect of texture and bulk density on rooting depth dynamics",
xaxis = list(title = "Temperature sum (TSUM)"),
yaxis = list(title = "Rooting depth zr")
)
)
