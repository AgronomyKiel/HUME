Dir.Results <- "P:/SimProject"
fn.Ctrl <- normalizePath(fn.Ctrl, winslash = "\\")
Dir.Results <- normalizePath(Dir.Results, winslash = "\\")
Parms <- c(fn.Ctrl, Dir.Results)
#ExeName <-paste0("C:\\Users\\neukam\\Nextcloud\\ubuntu_shared\\WheatSimOffline_\\Exe\\Exe",exe.str,".exe")
# glob.out.nc <- paste0("C:/Users/neukam/Nextcloud/ubuntu_shared/WheatSimOffline_/data/Ruthe/GO",exe.str,".csv")
#exe_nextcloud <- ExeName
local_exe <-"Q:/SimProject/project/Win32/Debug/SimProject1.exe"# file.path(tempdir(), "Exe1.exe")
