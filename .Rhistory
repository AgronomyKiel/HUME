theme_minimal()
p
#| echo: false
#| results: "asis"
#| message: false
#| warning: false
#| fig.cap: "Reduction factor for soil evaporation (f~evap~) as a function of soil water tension in the top soil layer (psi~arr~[1]) for a given critical soil water tension for evaporation reduction (psicritevap)."
psi_arr_1 <- seq(-14000, -1, by = 1) # Soil water tension in the top soil layer
psicritevap <- -500 # Critical soil water tension for evaporation reduction
fevap <- length(psi_arr_1)
fevap <- pmax(0, pmin(1,(-1 * (log10(-psi_arr_1) - 4.2)) / (4.2 - log10(-psicritevap))))
fevapBeese <- pmax(0, pmin(1, -0.5767 * log10(-psi_arr_1) + 1.78))
illu <- data.frame(psi_arr_1, fevap, fevapBeese)
illu <- pivot_longer(illu, cols = c("fevap", "fevapBeese"), names_to = "Method", values_to = "ReductionFactor")
p <- ggplot(data = illu) +
geom_line( aes(x = abs(psi_arr_1), y = ReductionFactor, group=ReductionFactor,color="Method"), size = 1) +
scale_x_log10() +
scale_color_manual(values = c("blue", "red"), labels = c("Modified Beese", "Original Beese")) +
labs(x = "Soil water tension in the top soil layer (psi_arr[1]) [kPa]",
y = "Reduction factor for soil evaporation (fevap)") +
theme_minimal()
p
View(illu)
