#| fig.cap: "Reduction factor for soil evaporation (f~evap~) as a function of soil water tension in the top soil layer (psi~arr~[1]) for a given critical soil water tension for evaporation reduction (psicritevap)."
psi_arr_1 <- seq(-1000, -1, by = 1) # Soil water tension in the top soil layer
psicritevap <- -1500 # Critical soil water tension for evaporation reduction
fevap <- (-1 * (log10(-psi_arr_1) - 4.2)) / (4.2 - log10(-psicritevap))
plot(psi_arr_1, fevap, type = "l", col = "blue", lwd = 2,
xlab = "Soil water tension in the top soil layer (psi_arr[1]) [kPa]",
ylab = "Reduction factor for soil evaporation (fevap)",
main = "Reduction factor for soil evaporation as a function of soil water tension")
