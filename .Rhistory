df2$rlds <- RLD0*exp(-RLDdec*df2$depths)
df2$sinkredf <- pmax(0,pmin(1, (df2$psis-psi3)/(psi2-psi3)))
df2 <- df2 %>% mutate(SumRLDComp = sum(sinkredf*rlds^CompF)) %>% ungroup()
df2 <- df2 %>% mutate(SinkTerm = 0.1*5*sinkredf*df2$rlds^CompF/SumRLDComp)
df2$option <- "Reduction by soil water potential"
df <- rbind(df1, df2)
p3 <- ggplot(df_psis, aes(y = depths, x = psis)) +
geom_line(size=1.5) +
geom_abline(xintercept = -10^1.8, linetype = "dashed", color = "blue") +
scale_y_reverse() +
labs(title = "", y = "Depth (cm)", x = "Soil water potential (hPa)") +
theme_minimal(base_size = 12)
#p3
p4 <- ggplot(df_psis, aes(y = depths, x = swc)) +
geom_line(size=1.5) +
scale_y_reverse() +
geom_vline(xintercept = FK, linetype = "dashed", color = "blue", size=1) +
geom_vline(xintercept = PWP, linetype = "dashed", color = "red", size=1) +
labs(title = "", y = "Depth (cm)", x = "Soil water content (cm3/cm3)") +
theme_minimal(base_size = 12)
#p4
df <- df %>% arrange(option, depths)
p5 <- ggplot(df, aes(y = depths, x = SinkTerm, color = option)) +
geom_line(aes(group=option),size=1.5) +
scale_y_reverse() +
scale_color_manual(values = c("blue", "red"), labels = c("No reduction", "Reduction by soil water potential")) +
labs(title = "", y = "Depth (cm)", x = "Sink Term (mm/d)", color = "Option") +
theme_minimal(base_size = 12)
#p5
p <- p3 + p4 + p5 + plot_layout(ncol = 3, guides = "collect") & theme(legend.position = "bottom")
p
#| echo: false
#| message: false
#| warning: false
#| fig-cap: "Example for the calculation of soil water potential and soil water content with depth based on the van Genuchten equation for a given set of parameters for a silty loam soil."
fn_RR <- "./Components/Soil/Documentation/GenuchtenPars_roteReihe.csv"
Params_RR <- read.table(fn_RR, header = TRUE, comment.char = "[", sep = ";", dec = ".")
Params_RR$Source <- "RR"
Params_RR$m <- 1-1/Params_RR$n
psis <- 1/depths^1.2*5e4
df_psis <- data.frame(depths, psis)
Params <- Params_RR %>% filter(Bodenart == "Sl3") %>% slice(1)
df_psis$swc <- Vectorize(swc) (psi=-df_psis$psis, alpha=Params$alpha,
n=Params$n,m=Params$m,theta_sat=Params$theta_s,
theta_res=Params$theta_r, lambda = Params$m * Params$n, type_swc = "VanGenuchten")
FK <- swc (psi=-10^1.8, alpha=Params$alpha,
n=Params$n,m=Params$m,theta_sat=Params$theta_s,
theta_res=Params$theta_r, lambda = Params$m * Params$n, type_swc = "VanGenuchten")
PWP <- swc (psi=-10^4.2, alpha=Params$alpha,
n=Params$n,m=Params$m,theta_sat=Params$theta_s,
theta_res=Params$theta_r, lambda = Params$m * Params$n, type_swc = "VanGenuchten")
CompF <- 1
df1 <- df_psis
df1$rlds <- RLD0*exp(-RLDdec*df1$depths)
df1 <- df1 %>% mutate(SumRLDComp = sum(rlds^CompF)) %>% ungroup()
df1 <- df1 %>% mutate(SinkTerm = 0.1*5*df1$rlds^CompF/SumRLDComp)
df1$sinkredf <- 1
df1$option <- "No reduction"
psi2 <- 200
psi3 <- 10^4.2
df2 <- df_psis
df2$rlds <- RLD0*exp(-RLDdec*df2$depths)
df2$sinkredf <- pmax(0,pmin(1, (df2$psis-psi3)/(psi2-psi3)))
df2 <- df2 %>% mutate(SumRLDComp = sum(sinkredf*rlds^CompF)) %>% ungroup()
df2 <- df2 %>% mutate(SinkTerm = 0.1*5*sinkredf*df2$rlds^CompF/SumRLDComp)
df2$option <- "Reduction by soil water potential"
df <- rbind(df1, df2)
p3 <- ggplot(df_psis, aes(y = depths, x = psis)) +
geom_line(size=1.5) +
geom_abline(xintercept = -10^1.8, linetype = "dashed", color = "blue") +
scale_y_reverse() +
labs(title = "", y = "Depth (cm)", x = "Soil water potential (hPa)") +
theme_minimal(base_size = 12)
#p3
p4 <- ggplot(df_psis, aes(y = depths, x = swc)) +
geom_line(size=1.5) +
scale_y_reverse() +
geom_vline(xintercept = FK, linetype = "dashed", color = "blue", size=1) +
geom_vline(xintercept = PWP, linetype = "dashed", color = "red", size=1) +
labs(title = "", y = "Depth (cm)", x = "Soil water content (cm3/cm3)") +
theme_minimal(base_size = 12)
#p4
df <- df %>% arrange(option, depths)
p5 <- ggplot(df, aes(y = depths, x = SinkTerm, color = option)) +
geom_line(aes(group=option),size=1.5) +
scale_y_reverse() +
scale_color_manual(values = c("blue", "red"), labels = c("No reduction", "Reduction by soil water potential")) +
labs(title = "", y = "Depth (cm)", x = "Sink Term (mm/d)", color = "Option") +
theme_minimal(base_size = 12)
#p5
p <- p3 + p4 + p5 + plot_layout(ncol = 3, guides = "collect") & theme(legend.position = "bottom")
p
View(df1)
View(df2)
