			<MSBuild Targets="Make" Projects="Components\Soil\SoilWaterPackage.dproj"/>
		</Target>
		<Target Name="Build">
			<CallTarget Targets="Hume1;SoilWaterPackage"/>
		</Target>
		<Target Name="Clean">
			<CallTarget Targets="Hume1:Clean;SoilWaterPackage:Clean"/>
