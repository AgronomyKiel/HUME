		</PropertyGroup>
		<ItemGroup>
			<Projects Include="Hume1.dproj">
				<Dependencies/>
			</Projects>
			<Projects Include="Components\Soil\SoilWaterPackage.dproj">
				<Dependencies/>
			</Projects>
		</ItemGroup>
		<ProjectExtensions>
			<Borland.Personality>Default.Personality.12</Borland.Personality>
			<Borland.ProjectType/>
			<BorlandProject>
				<Default.Personality/>
			</BorlandProject>
		</ProjectExtensions>
		<Target Name="Hume1">
			<MSBuild Projects="Hume1.dproj"/>
		</Target>
		<Target Name="Hume1:Clean">
			<MSBuild Targets="Clean" Projects="Hume1.dproj"/>
		</Target>
		<Target Name="Hume1:Make">
			<MSBuild Targets="Make" Projects="Hume1.dproj"/>
